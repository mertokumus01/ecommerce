# Docker Compose Environment Variables
# Copy this to .env.docker and update values as needed

# Oracle Database
ORACLE_PASSWORD=oracle123

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@oracle:1521:XEPDB1
SPRING_DATASOURCE_USERNAME=ECOMMERCEAPI
SPRING_DATASOURCE_PASSWORD=ecommerce123
SPRING_DATASOURCE_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_PROFILES_ACTIVE=production

# Frontend Configuration
NGINX_HOST=ecommerce.local
NGINX_PORT=80

# Optional: If using reverse proxy or load balancer
# BACKEND_URL=https://api.ecommerce.com
# FRONTEND_URL=https://ecommerce.com
